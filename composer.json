{
  "name": "guilhermesoares009/asynchronous-process-orchestration",
  "type": "project",
  "description": "Async workflow orchestration with Laravel and queues",
  "require": {
    "php": "^8.1",
    "laravel/framework": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@php artisan package:discover --ansi"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^7",
    "phpunit/phpunit": "^10"
  }
}
